{
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "rewrites": [
    {
      "source": "/portal/assets/:path*",
      "destination": "/portal/assets/:path*"
    },
    {
      "source": "/portal/(.*)",
      "destination": "/portal/index.html"
    },
    {
      "source": "/prototype",
      "destination": "/prototype.html"
    }
  ]
}
