{
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "redirects": [
    {
      "source": "/admin/:path*",
      "destination": "/portal/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/portal/(.*)",
      "destination": "/portal/index.html"
    },
    {
      "source": "/prototype",
      "destination": "/prototype.html"
    }
  ]
}
