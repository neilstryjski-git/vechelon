{
  "outputDirectory": "public",
  "rewrites": [
    {
      "source": "/admin/assets/:path*",
      "destination": "/admin/assets/:path*"
    },
    {
      "source": "/admin/(.*)",
      "destination": "/admin/index.html"
    },
    {
      "source": "/prototype",
      "destination": "/prototype.html"
    }
  ]
}
